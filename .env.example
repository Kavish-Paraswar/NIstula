PORT=3000
NODE_ENV=development

# Optional. Unset = persistence is skipped; the webhook still returns a drafted reply.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nistula_messages?schema=public

# Optional. Unset = deterministic fallback templates are used instead of Claude.
ANTHROPIC_API_KEY=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
